@page "/crops"
@inject HttpClient Http

<h2 class="mb-4">Crops</h2>

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger alert-dismissible">
        @error
        <button type="button" class="btn-close" @onclick="() => error = string.Empty"></button>
    </div>
}

@if (!showForm)
{
    <button class="btn btn-success mb-3" @onclick="ShowCreate">
        <i class="bi bi-plus-circle me-1"></i> New Crop
    </button>

    @if (items is null)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <div class="spinner-border spinner-border-sm"></div> Loading...
        </div>
    }
    else if (!items.Any())
    {
        <div class="alert alert-info">No crops registered yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-success">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Planted</th>
                        <th>Est. Harvest</th>
                        <th>Plot</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in items)
                    {
                        <tr>
                            <td class="text-muted small">@c.Id</td>
                            <td class="fw-semibold">@c.Name</td>
                            <td>@c.Type</td>
                            <td>
                                <span class="badge @(c.Status == "Active" ? "bg-success" : c.Status == "Harvested" ? "bg-secondary" : "bg-warning text-dark")">
                                    @c.Status
                                </span>
                            </td>
                            <td class="small">@c.PlantingDate.ToString("MM/dd/yyyy")</td>
                            <td class="small text-muted">@(c.EstimatedHarvestDate?.ToString("MM/dd/yyyy") ?? "—")</td>
                            <td class="small">@c.PlotName</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-warning me-1" @onclick="() => ShowEdit(c)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(c.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
else
{
    <div class="card" style="max-width:620px">
        <div class="card-header bg-success text-white fw-semibold">
            @(isEditing ? "Edit Crop" : "New Crop")
        </div>
        <div class="card-body">
            <EditForm Model="form" OnValidSubmit="Save">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="form.Name" placeholder="e.g. Cherry Tomatoes" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Type <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="form.Type" placeholder="e.g. Vegetable" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Planting Date</label>
                        <InputDate class="form-control" @bind-Value="form.PlantingDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Est. Harvest Date</label>
                        <InputDate class="form-control" @bind-Value="form.EstimatedHarvestDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <InputSelect class="form-select" @bind-Value="form.Status">
                            <option value="Active">Active</option>
                            <option value="Harvested">Harvested</option>
                            <option value="Lost">Lost</option>
                            <option value="Pending">Pending</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Plot <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="form.PlotId">
                            <option value="0">-- Select --</option>
                            @foreach (var p in plots)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Save
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">
                        Cancel
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<CropResponse>? items;
    private List<PlotResponse> plots = new();
    private CropForm form = new();
    private bool showForm, isEditing;
    private int editingId;
    private string error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        try { plots = await Http.GetFromJsonAsync<List<PlotResponse>>("api/plots") ?? new(); }
        catch { }
    }

    private async Task Load()
    {
        try { items = await Http.GetFromJsonAsync<List<CropResponse>>("api/crops"); }
        catch (Exception ex) { error = $"Error loading: {ex.Message}"; }
    }

    private void ShowCreate() { form = new(); isEditing = false; showForm = true; error = string.Empty; }

    private void ShowEdit(CropResponse c)
    {
        form = new()
        {
            Name = c.Name, Type = c.Type, PlantingDate = c.PlantingDate,
            EstimatedHarvestDate = c.EstimatedHarvestDate, Status = c.Status, PlotId = c.PlotId
        };
        editingId = c.Id; isEditing = true; showForm = true; error = string.Empty;
    }

    private async Task Save()
    {
        try
        {
            var res = isEditing
                ? await Http.PutAsJsonAsync($"api/crops/{editingId}", form)
                : await Http.PostAsJsonAsync("api/crops", form);

            if (res.IsSuccessStatusCode) { showForm = false; await Load(); }
            else error = $"Error saving: {res.StatusCode}";
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private async Task Delete(int id)
    {
        try
        {
            var res = await Http.DeleteAsync($"api/crops/{id}");
            if (res.IsSuccessStatusCode) await Load();
            else error = "Could not delete — the crop may have associated activity logs.";
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private void Cancel() { showForm = false; error = string.Empty; }
}

@using Microsoft.AspNetCore.Components

<a href="/" class="brand d-block mb-4 text-decoration-none">
    EcoRoot
</a>

<ul class="nav flex-column flex-grow-1">
    <li class="nav-item">
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
            <i class="bi bi-house-door me-2"></i> Home
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="/plots">
            <i class="bi bi-grid-3x3-gap me-2"></i> Plots
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="/crops">
            <i class="bi bi-flower2 me-2"></i> Crops
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="/students">
            <i class="bi bi-people me-2"></i> Students
        </NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="/activity-logs">
            <i class="bi bi-journal-text me-2"></i> Activities
        </NavLink>
    </li>
</ul>

<div class="px-2 mt-auto pt-3 border-top border-secondary">
    @if (!string.IsNullOrEmpty(Username))
    {
        <div class="text-white-50 small mb-2">
            <i class="bi bi-person-circle me-1"></i> @Username
        </div>
    }
    <button class="btn btn-sm btn-outline-light w-100" @onclick="OnLogout">
        <i class="bi bi-box-arrow-right me-1"></i> Sign Out
    </button>
</div>

@code {
    [Parameter] public string? Username { get; set; }
    [Parameter] public EventCallback OnLogout { get; set; }
}
